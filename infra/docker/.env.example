# Copy this file to .env and adjust values for your local setup.
# Never commit .env — it is gitignored.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=safequery
POSTGRES_PASSWORD=safequery_dev
POSTGRES_DB=safequery
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_dev_password
REDIS_PORT=6379

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_dev_password
KEYCLOAK_PORT=8080

# ── Cerbos ───────────────────────────────────────────────────────────────────
CERBOS_HTTP_PORT=3592
CERBOS_GRPC_PORT=3593

# ── TRE login credentials (created by postgres/init.sql) ─────────────────────
# These are Postgres login users that inherit the safequery_reader/writer roles.
# Override in production — never use these defaults.
TRE_READER_PASSWORD=tre_reader_dev
TRE_WRITER_PASSWORD=tre_writer_dev
