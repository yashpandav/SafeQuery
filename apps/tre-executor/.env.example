# DOCUMENTATION ONLY — apps/tre-executor has no dev/start script of its own
# (it's a library apps/tre-dispatcher imports and runs in-process), so a
# .env file here would never actually be loaded. Set these vars in
# apps/tre-dispatcher/.env instead — see that file's .env.example.
#
# apps/tre-executor is the ONLY component in this codebase allowed to hold
# CREDENTIAL_MASTER_KEY — it is the one place customer DB credentials get
# decrypted (and where a brand-new connection's credentials get encrypted).

NODE_ENV=development

CREDENTIAL_MASTER_KEY=replace_with_64_hex_chars_from_command_above

STATEMENT_TIMEOUT_MS=30000
LOCK_TIMEOUT_MS=5000
DEFAULT_ROW_CAP=10000

VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=safequery_vault_dev
