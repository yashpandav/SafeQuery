# Copy to .env — never commit .env

NODE_ENV=development
PORT=3001

# PostgreSQL — matches infra/docker/.env defaults
DATABASE_URL=postgresql://safequery:safequery_dev@localhost:5434/safequery

# PASETO v3.local symmetric key: 32 random bytes as hex (64 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PASETO_LOCAL_KEY=replace_with_64_hex_chars_from_command_above

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=safequery

# Cerbos — matches infra/docker/.env defaults
CERBOS_URL=http://localhost:3592

# Redis — matches infra/docker/.env defaults. apps/api enqueues execution
# jobs here; it never opens a connection to a customer database itself.
REDIS_URL=redis://:redis_dev_password@localhost:6380

# apps/ai-service
AI_SERVICE_URL=http://localhost:3002

# PASETO v4.public — base64-encoded PKCS8 PEM Ed25519 private key. Signs
# service tokens for calls to ai-service. Must pair with ai-service's
# SERVICE_PUBLIC_KEY — generate BOTH at once with (run from apps/api):
#   pnpm exec tsx -e "const {generateServiceKeypairBase64}=require('@repo/auth'); console.log(generateServiceKeypairBase64())"
# Put .privateKey here and .publicKey in apps/ai-service/.env's SERVICE_PUBLIC_KEY.
SERVICE_PRIVATE_KEY=replace_with_base64_private_key

# Allowed origin for CORS (the Next.js frontend)
CORS_ORIGIN=http://localhost:3000
