{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "PORT",
    "DATABASE_URL",
    "PASETO_LOCAL_KEY",
    "KEYCLOAK_URL",
    "KEYCLOAK_REALM",
    "CERBOS_URL",
    "CORS_ORIGIN",
    "NEXT_PUBLIC_API_URL",
    "AI_SERVICE_URL",
    "SERVICE_PRIVATE_KEY",
    "SERVICE_PUBLIC_KEY",
    "OPENAI_API_KEY",
    "AI_MODEL",
    "AI_SCREEN_MODEL",
    "REDIS_URL",
    "CREDENTIAL_MASTER_KEY",
    "STATEMENT_TIMEOUT_MS",
    "LOCK_TIMEOUT_MS",
    "DEFAULT_ROW_CAP",
    "WORKER_CONCURRENCY",
    "MAX_CONCURRENT_JOBS_PER_ORG",
    "LOG_LEVEL"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "!.next/dev/**",
        "dist/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    },
    "test": {
      "dependsOn": [
        "^build"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    }
  }
}